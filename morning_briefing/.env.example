# ============================================================
# Morning Briefing — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# Google Gemini API
# Get your key at: https://aistudio.google.com/app/apikey
# Free tier is sufficient for this workload.
# ----------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ----------------------------------------------------------
# Google Cloud Text-to-Speech
# 1. Create a project at https://console.cloud.google.com
# 2. Enable "Cloud Text-to-Speech API"
# 3. Create a service account, download JSON key
# 4. Set the path below
# Free tier: 1 million characters/month (Neural2 voices: 1M chars free)
# ----------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account-key.json

# ----------------------------------------------------------
# Gmail SMTP
# Use an App Password — NOT your main Google account password.
# Steps:
#   1. Enable 2FA on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create a new app password (select "Mail" + your device)
#   4. Copy the 16-character password below (spaces optional)
# ----------------------------------------------------------
GMAIL_ADDRESS=your.sender@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
